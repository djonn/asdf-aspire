#!/usr/bin/env bash

set -euo pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "$current_script_path")")

# shellcheck source=./lib/utils.bash
. "${plugin_dir}/lib/utils.bash"

# Get all versions, filter out pre-releases (anything with a hyphen), sort, and get the latest
version="$(list_all_versions | grep -v "-" | sort_versions | tail -n1 | xargs echo)"

printf "%s\n" "$version"
